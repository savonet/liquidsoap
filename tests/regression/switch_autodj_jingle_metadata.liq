# Regression test for stale jingle metadata in a delayed-jingle autodj.
#
# With `jingles = delay(d, playlist(...))` and `autodj = fallback([jingles,
# music])`, the first jingle plays, then music takes over while the delay
# elapses. When the jingles source is re-selected, replay_metadata used to
# inject the *previous* jingle's metadata over the new jingle's own metadata,
# so on_metadata reported the first jingle's title again instead of the new
# one.
#
# The sine mp3 files (with distinct titles) are generated by ffmpeg in the
# dune build. We check that the second jingle selection reports its own title
# ("jingle1"), not the stale "jingle0".

music = single("autodj_music.mp3")
jingles = delay(1.5, playlist(mode="normal", "autodj_jingles.m3u"))
autodj = fallback([jingles, music])
b = blank()
b.composition_type := "live"
radio = fallback([autodj, b])

log.level := 3

# 0: waiting for first jingle; 1: waiting for music; 2: waiting for 2nd jingle
state = ref(0)

radio.on_metadata(
  synchronous=true,
  fun (m) ->
    begin
      title = m["title"]
      is_jingle = string.contains(prefix="jingle", title)
      log(
        "state=#{state()}, title=#{title}"
      )
      if
        state() == 0 and is_jingle
      then
        state := 1
      elsif
        state() == 1 and not is_jingle
      then
        state := 2
      elsif
        state() == 2 and is_jingle
      then
        if title == "jingle1" then test.pass() else test.failed() end
      end
    end
)

#clock.assign_new(sync="none", [radio])
output.dummy(fallible=true, radio)
