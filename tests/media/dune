; Fetch DVD bitmap subtitle test file from FFmpeg FATE samples

(rule
 (alias test_bitmap_subtitle_to_video)
 (target fate-suite-filter-242_4.mkv)
 (action
  (run
   rsync
   -avL
   rsync://fate-suite.ffmpeg.org/fate-suite/filter/242_4.mkv
   %{target})))

(rule
 (alias test_bitmap_subtitle_to_video)
 (package liquidsoap)
 (target bitmap_subtitle_to_video_output.mp4)
 (deps
  fate-suite-filter-242_4.mkv
  test_bitmap_subtitle_to_video.liq
  ../../src/bin/liquidsoap.exe
  (package liquidsoap)
  (source_tree ../../src/lib)
  (:test_liq ../test.liq)
  (:run_test ../run_test.exe))
 (action
  (run
   %{run_test}
   "Bitmap subtitle to video conversion"
   liquidsoap
   %{test_liq}
   test_bitmap_subtitle_to_video.liq
   --
   fate-suite-filter-242_4.mkv)))

; Extract a frame at 4.00s from the encoded output for visual comparison

(rule
 (alias test_bitmap_subtitle_to_video)
 (deps bitmap_subtitle_to_video_output.mp4)
 (target bitmap_subtitle_to_video_output.jpg)
 (action
  (run
   ffmpeg
   -hide_banner
   -loglevel
   error
   -ss
   4.00
   -i
   bitmap_subtitle_to_video_output.mp4
   -frames:v
   1
   -q:v
   2
   %{target})))

; Compare generated image with reference using SSIM

(rule
 (alias test_bitmap_subtitle_to_video)
 (deps
  bitmap_subtitle_to_video_output.jpg
  (:reference bitmap_subtitle_to_video_reference.jpg))
 (action
  (bash
   "ssim=$(ffmpeg -hide_banner -i %{reference} -i bitmap_subtitle_to_video_output.jpg -lavfi ssim -f null - 2>&1 | grep -o 'All:[0-9.]*' | cut -d: -f2); echo \"SSIM: $ssim\"; awk \"BEGIN {exit ($ssim < 0.95) ? 1 : 0}\"")))

