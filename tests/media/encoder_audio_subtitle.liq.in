
log.level.set(4)

file = "@FILE@"

let {audio} = source.tracks(sine(duration=16.))
let {subtitle = m} = source.tracks((single("test-subtitle.srt"):source(audio=none,video=none,subtitle=subtitle(text))))

s = source({audio=audio, subtitle=m})

s = once(s)

clock.assign_new(sync="none",[s])

output.file(
  fallible=true,on_close=fun (_) -> test.pass(),
  reopen_on_error=fun (_) -> begin test.fail(); null end,
  @FORMAT@,file,s)
