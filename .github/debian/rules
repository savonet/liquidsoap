#!/usr/bin/make -f

DESTDIR := debian/tmp

%:
	dh $@

override_dh_autoreconf:
	/bin/true

override_dh_auto_configure:
	/bin/true

override_dh_auto_build:
	/bin/true

override_dh_auto_test:
	/bin/true

override_dh_auto_install:
	LIQUIDSOAP_BUILD_TARGET=posix LIQUIDSOAP_INSTALL_NO_OPTIONAL_FAIL=true dune build @install --release
	dune install --relocatable --prefix $(DESTDIR)
	mkdir -p $(DESTDIR)/share/liquidsoap
	cp -rf `opam var share`/camomile $(DESTDIR)/share/liquidsoap
	dh_install

override_dh_auto_clean:
	/bin/true
