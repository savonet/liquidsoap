(library
 (name ogg)
 (public_name ogg)
 (synopsis "OCaml bindings for libogg")
 (enabled_if
  (= %{read:../detect/ogg_available} true))
 (libraries threads)
 (modules ogg)
 (install_c_headers ocaml-ogg)
 (foreign_stubs
  (language c)
  (names ogg_stubs)
  (flags
   (:include ../detect/ogg_c_flags.sexp)))
 (c_library_flags
  (:include ../detect/ogg_c_library_flags.sexp)))

(rule
 (alias install)
 (package ogg)
 (action
  (with-stdin-from
   ../detect/ogg_available
   (run ../detect/check.exe ogg))))

(library
 (name ogg_decoder)
 (public_name ogg.decoder)
 (synopsis "Ogg decoding library with pluggable decoders")
 (optional)
 (libraries ogg)
 (modules ogg_decoder))
