(library
 (name theora)
 (public_name theora)
 (synopsis "OCaml bindings for libtheora")
 (enabled_if
  (= %{read:../detect/theora_available} true))
 (libraries ogg)
 (modules theora)
 (foreign_stubs
  (language c)
  (names theora_stubs)
  (flags
   (:include ../detect/theora_c_flags.sexp)))
 (c_library_flags
  (:include ../detect/theora_c_library_flags.sexp)))

(rule
 (alias install)
 (package theora)
 (enabled_if (not (= %{env:LIQ_RELEASE_AVAILABLE_OPTIONALS=false} true)))
 (action
  (with-stdin-from
   ../detect/theora_available
   (run ../detect/check.exe theora))))

(library
 (name theora_decoder)
 (public_name theora.decoder)
 (synopsis "Theora decoder for the ogg-decoder library")
 (optional)
 (libraries ogg.decoder theora)
 (modules theora_decoder))
