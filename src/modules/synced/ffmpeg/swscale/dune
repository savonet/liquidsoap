(rule
 (alias install)
 (package ffmpeg-swscale)
 (enabled_if
  (not
   (= %{env:LIQUIDSOAP_INSTALL_NO_OPTIONAL_FAIL=false} true)))
 (action
  (with-stdin-from
   ../detect/swscale_available
   (run ../detect/check.exe swscale))))

(library
 (name swscale)
 (public_name ffmpeg-swscale)
 (synopsis "Bindings to ffmpeg's swscale library")
 (enabled_if
  (= %{read:../detect/swscale_available} "true"))
 (foreign_stubs
  (language c)
  (names swscale_stubs)
  (flags
   (:include ../detect/swscale_c_flags.sexp)))
 (c_library_flags
  (:include ../detect/swscale_c_library_flags.sexp))
 (libraries ffmpeg-avutil))
