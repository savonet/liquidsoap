(rule
 (alias install)
 (package ffmpeg-avutil)
 (action
  (with-stdin-from
   ../detect/avutil_available
   (run ../detect/check.exe avutil))))

(library
 (name avutil)
 (public_name ffmpeg-avutil)
 (synopsis "Bindings to ffmpeg's avutil library")
 (enabled_if
  (= %{read:../detect/avutil_available} "true"))
 (foreign_stubs
  (language c)
  (names avutil_stubs)
  (flags
   (:include ../detect/avutil_c_flags.sexp)))
 (c_library_flags
  (:include ../detect/avutil_c_library_flags.sexp))
 (install_c_headers
  avutil_stubs
  polymorphic_variant_values_stubs
  media_types_stubs)
 (libraries threads))

(rule
 (targets avutil_stubs.c)
 (mode fallback)
 (deps
  polymorphic_variant_values_stubs.h
  pixel_format_stubs.h
  media_types_stubs.h
  hw_device_type_stubs.h
  pixel_format_flag_stubs.h
  color_space_stubs.h
  color_range_stubs.h
  color_primaries_stubs.h
  color_trc_stubs.h
  chroma_location_stubs.h
  sample_format_stubs.h
  channel_layout_stubs.h
  subtitle_type_stubs.h
  subtitle_flag_stubs.h)
 (action
  (echo "this should not happen")))

(rule
 (targets hw_device_type_stubs.h)
 (deps ../detect/avutil_c_flags)
 (action
  (run
   ../gen_code/gen_code.exe
   "%{cc}"
   hw_device_type
   h
   %{read-lines:../detect/avutil_c_flags})))

(rule
 (targets hw_device_type.ml)
 (deps hw_device_type_stubs.h ../detect/avutil_c_flags)
 (action
  (run
   ../gen_code/gen_code.exe
   "%{cc}"
   hw_device_type
   ml
   %{read-lines:../detect/avutil_c_flags})))

