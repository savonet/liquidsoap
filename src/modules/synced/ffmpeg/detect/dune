(executable
 (name detect)
 (libraries dune-configurator unix))

(executable
 (name check))

(executable
 (name all_available))

(rule
 (target all_libs_available)
 (deps
  avutil_available
  avcodec_available
  avfilter_available
  av_available
  swscale_available
  swresample_available
  avdevice_available)
 (action
  (with-stdout-to
   %{target}
   (run
    ./all_available.exe
    avutil_available
    avcodec_available
    avfilter_available
    av_available
    swscale_available
    swresample_available
    avdevice_available))))

(rule
 (targets
  avutil_available
  avutil_c_flags
  avutil_c_flags.sexp
  avutil_c_library_flags.sexp)
 (action
  (run
   ../detect/detect.exe
   --os-type
   %{os_type}
   --context
   %{context_name}
   avutil
   "libavutil libavcodec"
   "libavutil >= 55.78.100, libavcodec >= 57.107.100")))

(rule
 (targets
  avcodec_available
  avcodec_c_flags
  avcodec_c_flags.sexp
  avcodec_c_library_flags.sexp)
 (action
  (run
   ../detect/detect.exe
   --os-type
   %{os_type}
   --context
   %{context_name}
   avcodec
   libavcodec
   "libavcodec >= 59.24.100")))

(rule
 (targets av_available av_c_flags av_c_flags.sexp av_c_library_flags.sexp)
 (action
  (run
   ../detect/detect.exe
   --os-type
   %{os_type}
   --context
   %{context_name}
   av
   "libavutil libavformat"
   "libavutil >= 57.24.100, libavformat >= 57.83.100"
   -Wall
   -Wextra
   -Werror=unused-variable
   -Werror=unused-parameter)))

(rule
 (targets
  avfilter_available
