(library
 (name soundtouch)
 (public_name soundtouch)
 (synopsis "OCaml bindings for soundtouch")
 (enabled_if
  (= %{read:./detect/soundtouch_available} true))
 (libraries unix)
 (modules soundtouch)
 (foreign_stubs
  (language cxx)
  (names soundtouch_stubs)
  (flags
   (-fPIC
    (:include ./detect/soundtouch_c_flags.sexp))))
 (c_library_flags
  (-lstdc++
   (:include ./detect/soundtouch_c_library_flags.sexp))))

(rule
 (alias install)
 (package soundtouch)
 (enabled_if
  (not
   (= %{env:LIQUIDSOAP_INSTALL_NO_OPTIONAL_FAIL=false} true)))
 (action
  (with-stdin-from
   ./detect/soundtouch_available
   (run ./detect/check.exe soundtouch))))
