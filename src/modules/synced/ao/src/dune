(library
 (name ao)
 (public_name ao)
 (synopsis "OCaml bindings for ao")
 (enabled_if
  (= %{read:./detect/ao_available} true))
 (modules ao)
 (foreign_stubs
  (language c)
  (names ao_stubs)
  (flags
   (:include ./detect/ao_c_flags.sexp)))
 (c_library_flags
  (:include ./detect/ao_c_library_flags.sexp)))

(rule
 (alias install)
 (package ao)
 (enabled_if
  (not
   (= %{env:LIQUIDSOAP_INSTALL_NO_OPTIONAL_FAIL=false} true)))
 (action
  (with-stdin-from
   ../detect/ao_available
   (run ../detect/check.exe ao))))
