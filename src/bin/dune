(executable
 (name liquidsoap)
 (public_name liquidsoap)
 (package liquidsoap)
 (link_flags
  -cclib
  %{env:LIQUIDSOAP_LDFLAGS=}
  (:include macos_link_flags.sexp))
 (libraries liquidsoap_runtime))

(rule
 (target macos_link_flags.sexp)
 (enabled_if
  (= %{ocaml-config:system} macosx))
 (action
  (with-stdout-to
   %{target}
   (echo "(-cclib -Wl,-no_warn_duplicate_libraries)"))))

(rule
 (target macos_link_flags.sexp)
 (enabled_if
  (not
   (= %{ocaml-config:system} macosx)))
 (action
  (with-stdout-to
   %{target}
   (echo "()"))))

(rule
 (target liquidsoap-macos-instruments.exe)
 (enabled_if %{bin-available:codesign})
 (deps ./liquidsoap.exe ./instruments.plist)
 (action
  (progn
   (copy ./liquidsoap.exe ./liquidsoap-macos-instruments.exe)
   (run
    codesign
    -s
    -
    -v
    -f
    --entitlements
    instruments.plist
    liquidsoap-macos-instruments.exe))))
